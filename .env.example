# Copy to .env and fill in.

# HuggingFace token for model downloads.
HF_TOKEN=

# The model id you actually serve. Must match whatever you pass to vLLM
# via scripts/start_vllm.sh - if you serve an FP8 / AWQ / GPTQ variant,
# the model id here changes accordingly. The agent uses this for its
# chat-completions requests.
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# Optional: point the agent at any OpenAI-compatible API, including Nebius, so
# you can build and debug the graph without a running vLLM. This code reads
# OPENAI_API_KEY for hosted providers; do not use NEBIUS_API_KEY unless you also
# change agent/graph.py to read it. Switch back to the local vLLM defaults for
# final prompt tuning, evals, screenshots, and all reported SLO numbers.
# VLLM_BASE_URL=https://<nebius-openai-compatible-host>/v1
# VLLM_MODEL=<nebius-qwen-model-id>
# OPENAI_API_KEY=<nebius-api-key>
# VLLM_BASE_URL=https://api.openai.com/v1
# VLLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Langfuse keys - you'll get these in Phase 4 after creating a project
# in the local Langfuse UI at http://localhost:3001.
# Tag hosted API runs as environment=staging / inference_backend=hosted_api,
# and final H100 vLLM runs as environment=prod / inference_backend=vllm.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_TRACING_ENVIRONMENT=staging
